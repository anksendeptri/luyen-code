// bai 3
#include <iostream>
#include <vector>

using namespace std;
 
void nhap(vector<int>& a) 
{
    int temp; 
    for (int i = 0; i < 5; i++)
    {
        cin >> temp;
        a.push_back(temp);
    }
}

void xuat (vector<int> a)
{
    for (int i = 0; i < a.size(); i++)
    cout << a[i] << " ";
    cout << endl;
}
vector<int> locSo(const vector<int>& a)
{
    vector<int> b;
    for (int x : a)
       if (x % 2 == 0) b.push_back(x);
    return b;
}
int main()
{
    vector<int> a; 
    nhap(a);
    vector<int> s = locSo(a);
    xuat(s);
    return 0;
}


